{
  "manifest_version": 3,
  "name": "PhishLens",
  "version": "1.0",
  "description": "One-click phishing forensics on any Gmail email",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://mail.google.com/*", "http://localhost:3001/*"],
  "action": { "default_popup": "popup.html", "default_icon": "icon128.png" },
  "content_scripts": [{
    "matches": ["https://mail.google.com/*"],
    "js": ["content.js"]
  }],
  "background": { "service_worker": "background.js" }
}
